"prof"  # QuickTime Profile Atom
"enof"  # QuickTime Encoded Pixels Dimensions

# ── Brand identifiers (ftyp.major_brand / compatible_brands) ─────────────────
"isom"  # ISO Base Media
"iso2"
"iso6"
"mp41"  # MP4 v1
"mp42"  # MP4 v2
"M4V "  # iTunes Video
"M4A "  # iTunes Audio
"M4P "  # iTunes Protected
"M4B "  # iTunes Audiobook
"qt  "  # QuickTime
"avc1"
"dash"  # MPEG-DASH
"cmfc"  # Common Media Application Format
"avif"  # AV1 Image File Format
"heic"  # High Efficiency Image
"heif"
"mif1"
"msf1"  # HEVC image sequence

# ── Numeric field patterns ────────────────────────────────────────────────────
"\x00\x00\x00\x00"   # Zero size (extends to EOF — triggers patch_boxes)
"\x00\x00\x00\x08"   # Minimal valid box size (header only)
"\x00\x00\x00\x01"   # Extended 64-bit size indicator
"\x00\x00\x00\x10"   # 16-byte box
"\x00\x00\x00\x1c"   # 28-byte box
"\x00\x00\x00\x20"   # 32-byte box
"\xff\xff\xff\xff"   # Max 32-bit size
"\x00\x00\x00\x00\x00\x00\x00\x10"  # 64-bit size = 16

# ── Version/flags combos ──────────────────────────────────────────────────────
"\x00\x00\x00\x00"   # version=0 flags=0
"\x01\x00\x00\x00"   # version=1 flags=0

# ── Additional box FourCCs — HEIF/AVIF/HEVC/DASH/segment boxes ──────────────
"stco"  # Sample-to-chunk offset
"co64"  # 64-bit chunk offset
"ctts"  # Composition time offset
"stsc"  # Sample-to-chunk
"stsz"  # Sample size
"stz2"  # Compact sample size
"sdtp"  # Sample dependency type
"sbgp"  # Sample-to-group
"sgpd"  # Sample group description
"subs"  # Sub-sample information
"padb"  # Padding bits
"stsh"  # Shadow sync sample
"stsa"  # ?

