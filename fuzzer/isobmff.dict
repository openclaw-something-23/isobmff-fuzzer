# ── Version/flags magic values ────────────────────────────────────────────────
"\x01\x00\x00\x00"   # version=1 (large MVHD/TKHD)
"\x02\x00\x00\x00"   # version=2 (rare)
"\x00\x00\x00\x01"   # flags=1
"\x00\x00\x00\x02"   # flags=2
"\x00\x00\x00\x03"   # flags=3 (track_enabled|track_in_movie)
"\x00\x00\x00\x0f"   # flags=0x0f (all 4 track flags set)
"\x00\x00\x01\x00"   # flags=0x100
"\x00\x01\x00\x00"   # flags=0x10000
"\x00\x00\x07\xff"   # flags=0x7ff (many bits)
"\xff\x00\x00\x00"   # version=255 (invalid, boundary test)

# ── Common field sizes and offsets ────────────────────────────────────────────
"\x00\x00\x00\x18"   # 24 bytes (small box)
"\x00\x00\x00\x24"   # 36 bytes
"\x00\x00\x00\x38"   # 56 bytes (MVHD v0 size)
"\x00\x00\x00\x6c"   # 108 bytes (MVHD v1 size)
"\x00\x00\x00\x5c"   # 92 bytes (TKHD v0 size)
"\x00\x00\x00\x98"   # 152 bytes (TKHD v1 size)
"\x00\x00\x00\x1c"   # 28 bytes (minimal STTS/CTTS)
"\x00\x00\x00\x1a"   # 26 bytes (minimal MDHD v0)
"\x00\x00\x00\x2a"   # 42 bytes (minimal MDHD v1)

# ── Fixed-point and time values ───────────────────────────────────────────────
"\x00\x01\x00\x00"   # 1.0 in 16.16 fixed-point (width/height matrix)
"\x00\x04\x00\x00"   # 4.0 in 16.16
"\x40\x00\x00\x00"   # 1.0 in 2.30 fixed-point (volume=1.0)
"\x00\x01\x5f\x90"   # 90000 (common video timescale)
"\x00\x00\xac\x44"   # 44100 (audio sample rate)
"\x00\x00\xbb\x80"   # 48000 (audio sample rate)
"\x00\x01\xd4\xc0"   # 120000 (timescale)
"\x00\x00\x03\xe8"   # 1000 (ms timescale)

# ── ESDS descriptor tags ──────────────────────────────────────────────────────
"\x03"               # ES_Descriptor tag
"\x04"               # DecoderConfigDescriptor tag
"\x05"               # DecoderSpecificInfo tag
"\x06"               # SLConfigDescriptor tag
"\x0f"               # ObjectTypeIndication: Video ISO/IEC 14496-2
"\x20"               # ObjectTypeIndication: Video ISO/IEC 14496-2 (AAC)
"\x40"               # ObjectTypeIndication: Audio ISO/IEC 14496-3 (AAC)
"\x6b"               # ObjectTypeIndication: Audio ISO/IEC 11172-3 (MP3)
"\x69"               # ObjectTypeIndication: Audio ISO/IEC 13818-7 (AAC)
"\x80\x80\x80"       # 3-byte expandable size (common ESDS pattern)

# ── UUID values (extended box types) ─────────────────────────────────────────
"\xa2\x39\x4f\x52\x5a\x9b\x4f\x14\xa2\x44\x6c\x42\x7c\x64\x8d\xf4"  # PIFF
"\xd4\x80\x7e\xf2\xca\x39\x46\x95\x8e\x54\x26\xcb\x9e\x46\xa7\x9f"  # PIFF protection
"\xa2\x38\x47\x2e\x14\xfe\x11\xb7\xa1\xe6\xdc\x27\xb4\x35\x70\x11"  # DASH AdaptationSet
"\x6d\x1d\x9b\x05\x42\xd5\x44\xe6\x80\xe2\x14\x1d\xaf\xf7\x57\xb2"  # Microsoft PIFF TFXd
