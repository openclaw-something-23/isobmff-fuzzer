# Build artifacts
fuzzer/fuzz_isobmff
fuzzer/fuzz_isobmff_afl
fuzzer/fuzz_isobmff_replay
*.o *.a

# AFL++ sync dirs (large, gitignored)
results/afl_out/

# Run logs (too many small files — use meta.json only)
results/runs/*/fuzzer.log

# Large result files (crashes, coverage html) — keep only metadata
results/crashes/*.mp4
results/crashes/*.mov
results/crashes/*.bin
results/coverage/*.html
results/coverage/*.profdata
results/coverage/*.profraw

# But keep metadata
!results/runs/**/meta.json
!results/crashes/*.json
!results/coverage/*_lines.txt
!results/coverage/*_funcs.txt
!results/coverage/*_summary.json

# DB (regenerated from files)
results/fuzzer.db
results/fuzzer.db-*

# Temp
/tmp/*.profraw
/tmp/*.profdata
__pycache__/
*.pyc
.env
results/mp4gen_work/
results/seeds_ok/
results/*.dict
results/*.so
results/fuzz_isobmff_afl_new
results/live_stats.json
results/mp4gen_stats.json
results/mp4gen.log
results/.mp4gen_stuck_count
results/.schedule_idx
results/cmin_new/
results/runs/*/fuzzer_s*.log
